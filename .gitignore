.DS_Store
.venv/
__pycache__/
*.pyc

# Runtime data — never commit user/server runtime artifacts.
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/email_dispatch_log.json
data/yahoo_storage/

# Daily report artifacts (generated by daily_refresh, not source of truth).
# Keep reports/index.json under version control so links don't break.
reports/*.html
reports/*.txt

# Stock prediction artifacts (generated per ticker).
outputs/feature_importance_*.csv
outputs/latest_prediction_*.json
outputs/monthly_feature_table_*.csv
outputs/prediction_backtest_*.csv
outputs/prediction_summary_*.json
